<Window x:Class="AuraScan_Ultrasound_System.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="720" Height="480"
        ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Glow effect for logo text -->
        <DropShadowEffect x:Key="CyanGlow" Color="#00D4FF" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
        <DropShadowEffect x:Key="BlueGlow" Color="#0066CC" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="SubtleGlow" Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
    </Window.Resources>

    <!-- Main container with rounded corners -->
    <Border CornerRadius="16" ClipToBounds="True">
        <Grid x:Name="RootGrid">

            <!-- ═══ LAYER 0: Deep background gradient ═══ -->
            <Border CornerRadius="16">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.4" RadiusX="0.8" RadiusY="0.9">
                        <GradientStop Color="#0D1B2A" Offset="0"/>
                        <GradientStop Color="#0A0F1A" Offset="0.6"/>
                        <GradientStop Color="#050810" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- ═══ LAYER 1: Ultrasound sector/fan overlay ═══ -->
            <Canvas ClipToBounds="True">
                <!-- Sector fan cone (simulated convex probe field) -->
                <Path Canvas.Left="260" Canvas.Top="-40" Opacity="0.08"
                      Fill="#00D4FF"
                      Data="M 100,0 L 0,400 A 200,200 0 0 0 200,400 Z"/>

                <!-- Grid lines (ultrasound depth markers) -->
                <Line X1="310" Y1="60" X2="210" Y2="380" Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.06"/>
                <Line X1="360" Y1="60" X2="360" Y2="400" Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.08"/>
                <Line X1="410" Y1="60" X2="510" Y2="380" Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.06"/>

                <!-- Horizontal depth arcs -->
                <Path Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.05"
                      Data="M 250,150 Q 360,120 470,150"/>
                <Path Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.05"
                      Data="M 220,250 Q 360,210 500,250"/>
                <Path Stroke="#00D4FF" StrokeThickness="0.5" Opacity="0.04"
                      Data="M 190,350 Q 360,300 530,350"/>
            </Canvas>

            <!-- ═══ LAYER 2: Animated scanning sweep line ═══ -->
            <Canvas ClipToBounds="True">
                <Line x:Name="ScanLine" X1="360" Y1="20" X2="260" Y2="400"
                      Stroke="#00D4FF" StrokeThickness="1.5" Opacity="0.3">
                    <Line.Effect>
                        <BlurEffect Radius="2"/>
                    </Line.Effect>
                </Line>
            </Canvas>

            <!-- ═══ LAYER 3: Animated concentric pulse rings ═══ -->
            <Canvas ClipToBounds="True">
                <!-- Ring 1 -->
                <Ellipse x:Name="PulseRing1" Canvas.Left="310" Canvas.Top="165"
                         Width="100" Height="100" Opacity="0"
                         Stroke="#00D4FF" StrokeThickness="1.5" Fill="Transparent"/>
                <!-- Ring 2 -->
                <Ellipse x:Name="PulseRing2" Canvas.Left="310" Canvas.Top="165"
                         Width="100" Height="100" Opacity="0"
                         Stroke="#00B4D8" StrokeThickness="1" Fill="Transparent"/>
                <!-- Ring 3 -->
                <Ellipse x:Name="PulseRing3" Canvas.Left="310" Canvas.Top="165"
                         Width="100" Height="100" Opacity="0"
                         Stroke="#0096C7" StrokeThickness="0.8" Fill="Transparent"/>
            </Canvas>

            <!-- ═══ LAYER 4: Particle dots (floating data points) ═══ -->
            <Canvas ClipToBounds="True">
                <Ellipse x:Name="Dot1" Width="3" Height="3" Fill="#00D4FF" Opacity="0" Canvas.Left="180" Canvas.Top="120"/>
                <Ellipse x:Name="Dot2" Width="2" Height="2" Fill="#48CAE4" Opacity="0" Canvas.Left="520" Canvas.Top="200"/>
                <Ellipse x:Name="Dot3" Width="4" Height="4" Fill="#00D4FF" Opacity="0" Canvas.Left="150" Canvas.Top="300"/>
                <Ellipse x:Name="Dot4" Width="2" Height="2" Fill="#90E0EF" Opacity="0" Canvas.Left="550" Canvas.Top="140"/>
                <Ellipse x:Name="Dot5" Width="3" Height="3" Fill="#48CAE4" Opacity="0" Canvas.Left="480" Canvas.Top="340"/>
                <Ellipse x:Name="Dot6" Width="2" Height="2" Fill="#00D4FF" Opacity="0" Canvas.Left="240" Canvas.Top="350"/>
            </Canvas>

            <!-- ═══ LAYER 5: Main content ═══ -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <!-- ── Logo area ── -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Ultrasound probe icon (vector) -->
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Canvas.RenderTransform>
                            <ScaleTransform x:Name="ProbeIconScale" ScaleX="0" ScaleY="0" CenterX="40" CenterY="40"/>
                        </Canvas.RenderTransform>
                        <!-- Probe body -->
                        <Path Fill="#00D4FF" Opacity="0.9"
                              Data="M 30,15 L 50,15 Q 55,15 55,20 L 58,55 Q 58,60 53,62 L 27,62 Q 22,60 22,55 L 25,20 Q 25,15 30,15 Z"/>
                        <!-- Probe head (convex curve) -->
                        <Path Fill="#00B4D8"
                              Data="M 22,55 Q 40,75 58,55 L 53,62 Q 40,70 27,62 Z"/>
                        <!-- Wave arcs emanating from probe -->
                        <Path Stroke="#48CAE4" StrokeThickness="1.5" Fill="Transparent" Opacity="0.7"
                              Data="M 25,68 Q 40,82 55,68"/>
                        <Path Stroke="#48CAE4" StrokeThickness="1.2" Fill="Transparent" Opacity="0.5"
                              Data="M 20,73 Q 40,90 60,73"/>
                        <Path Stroke="#48CAE4" StrokeThickness="0.8" Fill="Transparent" Opacity="0.3"
                              Data="M 15,78 Q 40,98 65,78"/>
                        <!-- Screen on probe -->
                        <Rectangle Canvas.Left="32" Canvas.Top="22" Width="16" Height="10" 
                                   RadiusX="2" RadiusY="2" Fill="#0D1B2A" Opacity="0.6"/>
                        <Rectangle Canvas.Left="34" Canvas.Top="24" Width="12" Height="6" 
                                   RadiusX="1" RadiusY="1" Fill="#00D4FF" Opacity="0.3"/>
                    </Canvas>

                    <!-- AuraScan title -->
                    <TextBlock x:Name="LogoText" 
                               Text="AuraScan" FontSize="52" FontWeight="Bold"
                               FontFamily="Segoe UI Light"
                               Foreground="#00D4FF" HorizontalAlignment="Center"
                               Effect="{StaticResource CyanGlow}" Opacity="0">
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock x:Name="SubtitleText"
                               Text="U L T R A S O U N D   I M A G I N G   S Y S T E M" FontSize="11"
                               FontFamily="Segoe UI" FontWeight="SemiBold"
                               Foreground="#48CAE4" HorizontalAlignment="Center"
                               Opacity="0" Margin="0,4,0,0">
                    </TextBlock>

                    <!-- Accent line -->
                    <Border x:Name="AccentLine" Height="2" Width="0" Margin="0,12,0,0"
                            HorizontalAlignment="Center" CornerRadius="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#00D4FF" Offset="0.3"/>
                                <GradientStop Color="#48CAE4" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- ── Probe model ── -->
                <TextBlock x:Name="ProbeText" Grid.Row="1"
                           Text="Philips C5-1 Convex Probe  ·  1–5 MHz"
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="#5A7A9A" HorizontalAlignment="Center"
                           Opacity="0" Margin="0,0,0,8"/>

                <!-- ── Loading status ── -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <!-- Progress bar -->
                    <Border Width="300" Height="3" CornerRadius="1.5" Background="#1A2940">
                        <Border x:Name="ProgressFill" Height="3" CornerRadius="1.5"
                                HorizontalAlignment="Left" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0066CC" Offset="0"/>
                                    <GradientStop Color="#00D4FF" Offset="0.5"/>
                                    <GradientStop Color="#48CAE4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusText" 
                               Text="Initializing..."
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="#5A7A9A" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ── Developer branding ── -->
                <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock x:Name="DevByText"
                               Text="Developed by" FontSize="9"
                               FontFamily="Segoe UI" Foreground="#3A5068"
                               HorizontalAlignment="Center" Opacity="0"/>
                    <TextBlock x:Name="CompanyText"
                               Text="Rheacon Systems" FontSize="16" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="#7EB8DA" HorizontalAlignment="Center"
                               Opacity="0" Margin="0,2,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- ── Version and copyright ── -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock x:Name="VersionText"
                               Text="Version 1.0.0  ·  Medical Imaging Platform"
                               FontSize="9" FontFamily="Segoe UI"
                               Foreground="#2A4058" HorizontalAlignment="Center" Opacity="0"/>
                    <TextBlock x:Name="CopyrightText"
                               Text="© 2024 Rheacon Systems. All rights reserved."
                               FontSize="8" FontFamily="Segoe UI"
                               Foreground="#1E3448" HorizontalAlignment="Center"
                               Margin="0,2,0,0" Opacity="0"/>
                </StackPanel>

                <!-- Bottom edge glow -->
                <Border Grid.Row="5" VerticalAlignment="Bottom" Height="1" Opacity="0.3">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00D4FF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- ═══ Border outline glow ═══ -->
            <Border CornerRadius="16" BorderThickness="1" IsHitTestVisible="False">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A3050" Offset="0"/>
                        <GradientStop Color="#00D4FF" Offset="0.5"/>
                        <GradientStop Color="#0A3050" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Opacity>0.3</Border.Opacity>
            </Border>
        </Grid>

        <!-- ═══════════ ANIMATIONS ═══════════ -->
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>

                        <!-- ── Probe icon scale in (bounce) ── -->
                        <DoubleAnimation Storyboard.TargetName="ProbeIconScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         From="0" To="1" Duration="0:0:0.6"
                                         BeginTime="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="ProbeIconScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         From="0" To="1" Duration="0:0:0.6"
                                         BeginTime="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!-- ── Logo text fade in ── -->
                        <DoubleAnimation Storyboard.TargetName="LogoText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.8"
                                         BeginTime="0:0:0.5">
                            <DoubleAnimation.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!-- ── Subtitle fade in ── -->
                        <DoubleAnimation Storyboard.TargetName="SubtitleText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.8" Duration="0:0:0.6"
                                         BeginTime="0:0:0.9"/>

                        <!-- ── Accent line width expand ── -->
                        <DoubleAnimation Storyboard.TargetName="AccentLine"
                                         Storyboard.TargetProperty="Width"
                                         From="0" To="200" Duration="0:0:0.7"
                                         BeginTime="0:0:1.0">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!-- ── Probe text fade in ── -->
                        <DoubleAnimation Storyboard.TargetName="ProbeText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.7" Duration="0:0:0.5"
                                         BeginTime="0:0:1.3"/>

                        <!-- ── Developer branding fade in ── -->
                        <DoubleAnimation Storyboard.TargetName="DevByText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.7" Duration="0:0:0.5"
                                         BeginTime="0:0:1.5"/>
                        <DoubleAnimation Storyboard.TargetName="CompanyText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.6"
                                         BeginTime="0:0:1.6"/>

                        <!-- ── Version/copyright fade in ── -->
                        <DoubleAnimation Storyboard.TargetName="VersionText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.6" Duration="0:0:0.4"
                                         BeginTime="0:0:1.8"/>
                        <DoubleAnimation Storyboard.TargetName="CopyrightText"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.5" Duration="0:0:0.4"
                                         BeginTime="0:0:1.9"/>

                        <!-- ═══ Pulse Ring 1 — repeating expand + fade ═══ -->
                        <DoubleAnimation Storyboard.TargetName="PulseRing1"
                                         Storyboard.TargetProperty="Width"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:0.8" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing1"
                                         Storyboard.TargetProperty="Height"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:0.8" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing1"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0.5" To="0" Duration="0:0:2.5"
                                         BeginTime="0:0:0.8" RepeatBehavior="Forever"/>

                        <!-- Pulse Ring 2 — delayed -->
                        <DoubleAnimation Storyboard.TargetName="PulseRing2"
                                         Storyboard.TargetProperty="Width"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:1.6" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing2"
                                         Storyboard.TargetProperty="Height"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:1.6" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing2"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0.4" To="0" Duration="0:0:2.5"
                                         BeginTime="0:0:1.6" RepeatBehavior="Forever"/>

                        <!-- Pulse Ring 3 — further delayed -->
                        <DoubleAnimation Storyboard.TargetName="PulseRing3"
                                         Storyboard.TargetProperty="Width"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:2.4" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing3"
                                         Storyboard.TargetProperty="Height"
                                         From="20" To="200" Duration="0:0:2.5"
                                         BeginTime="0:0:2.4" RepeatBehavior="Forever"/>
                        <DoubleAnimation Storyboard.TargetName="PulseRing3"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0.3" To="0" Duration="0:0:2.5"
                                         BeginTime="0:0:2.4" RepeatBehavior="Forever"/>

                        <!-- ═══ Scan line sweep — rotating back and forth ═══ -->
                        <DoubleAnimation Storyboard.TargetName="ScanLine"
                                         Storyboard.TargetProperty="X2"
                                         From="210" To="510" Duration="0:0:2"
                                         BeginTime="0:0:0.5"
                                         AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="ScanLine"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0.15" To="0.35" Duration="0:0:1"
                                         AutoReverse="True" RepeatBehavior="Forever"/>

                        <!-- ═══ Floating particles ═══ -->
                        <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.6" Duration="0:0:1.5"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:0.3"/>
                        <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.4" Duration="0:0:2"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:0.7"/>
                        <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.5" Duration="0:0:1.8"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:1.1"/>
                        <DoubleAnimation Storyboard.TargetName="Dot4" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.3" Duration="0:0:2.2"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>
                        <DoubleAnimation Storyboard.TargetName="Dot5" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.5" Duration="0:0:1.6"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:1.4"/>
                        <DoubleAnimation Storyboard.TargetName="Dot6" Storyboard.TargetProperty="Opacity"
                                         From="0" To="0.4" Duration="0:0:1.9"
                                         AutoReverse="True" RepeatBehavior="Forever" BeginTime="0:0:0.9"/>

                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</Window>
