<Window x:Class="AuraScan_Ultrasound_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AuraScan_Ultrasound_System"
        xmlns:conv="clr-namespace:AuraScan_Ultrasound_System.Converters;assembly=AuraScan.Core"
        xmlns:vm="clr-namespace:AuraScan_Ultrasound_System.ViewModels;assembly=AuraScan.Core"
        mc:Ignorable="d"
        Title="AuraScan Ultrasound System — Philips C5-1"
        Height="900" Width="1440"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1A1A2E">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ImagingModeToStringConverter x:Key="ModeToStr"/>
        <conv:AcquisitionStateToColorConverter x:Key="StateToColor"/>
        <conv:ImagingModeEqualityConverter x:Key="ModeEquality"/>
        <conv:DepthDisplayConverter x:Key="DepthDisplay"/>
        <conv:DoubleFormatConverter x:Key="DoubleFmt"/>
        <conv:ProbeConnectionStateToColorConverter x:Key="ProbeStateColor"/>
        <conv:BatteryLevelToColorConverter x:Key="BatteryLevelColor"/>
        <conv:BatteryLevelToWidthConverter x:Key="BatteryLevelWidth"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Dark medical theme styles -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00B4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style x:Key="ActiveModeButton" TargetType="Button" BasedOn="{StaticResource ModeButton}">
            <Setter Property="Background" Value="#00B4D8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ControlLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="TgcSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="TickFrequency" Value="0.1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>

        <!-- Dark themed ComboBox toggle button -->
        <Style x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Margin="6,2"/>
                                <Path Grid.Column="1" Data="M0,0 L4,4 8,0" Stroke="#8888AA" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark themed ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#2D2D44"
                                        BorderBrush="#3A3A5C" BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,1,0,0">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark themed ComboBoxItem -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#00B4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="BorderBrush" Value="#2D2D44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Top bar: patient/probe info -->
            <RowDefinition Height="Auto"/>  <!-- Mode toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR: Patient & Probe Info ═══ -->
        <Border Grid.Row="0" Background="#0F3460" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- AuraScan logo/name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="24" Foreground="#00B4D8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="AuraScan" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" Ultrasound" FontSize="20" Foreground="#8888AA" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Patient info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0" VerticalAlignment="Center">
                    <TextBlock Text="Patient:" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding PatientInfo.PatientName, FallbackValue='No Patient'}"
                               Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="ID:" Foreground="#8888AA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding PatientInfo.PatientId, FallbackValue='—'}"
                               Foreground="#00E5FF" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Probe info -->
                <TextBlock Grid.Column="2" Text="{Binding ProbeInfo}" Foreground="#00E5FF"
                           FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Safety indices -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#2D2D44" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MI " Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="{Binding MechanicalIndex, Converter={StaticResource DoubleFmt}, ConverterParameter=F2}"
                                       Foreground="#FFD700" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2D2D44" CornerRadius="3" Padding="6,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TI " Foreground="#8888AA" FontSize="11"/>
                            <TextBlock Text="{Binding ThermalIndex, Converter={StaticResource DoubleFmt}, ConverterParameter=F2}"
                                       Foreground="#FFD700" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Battery indicator (visible only when on battery / not plugged into AC) -->
                <Border Grid.Column="4" Background="#2D2D44" CornerRadius="4" Padding="8,3" Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsOnBattery, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Battery icon graphic -->
                        <Grid Width="28" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                            <!-- Battery body outline -->
                            <Border BorderBrush="#8888AA" BorderThickness="1.5" CornerRadius="2"
                                    Width="24" Height="12" HorizontalAlignment="Left"/>
                            <!-- Battery terminal nub -->
                            <Border Background="#8888AA" Width="3" Height="6" CornerRadius="0,1,1,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <!-- Battery fill bar (proportional to level) -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="2.5,2,0,2" CornerRadius="1"
                                    Height="8"
                                    Width="{Binding BatteryPercent, Converter={StaticResource BatteryLevelWidth}, ConverterParameter=19}"
                                    Background="{Binding BatteryPercent, Converter={StaticResource BatteryLevelColor}}"/>
                            <!-- Charging bolt overlay -->
                            <TextBlock Text="⚡" FontSize="8" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IsBatteryCharging, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <!-- Percentage text -->
                        <TextBlock Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryLevelColor}}"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}%">
                                    <Binding Path="BatteryPercent"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <!-- Remaining time (if available) -->
                        <TextBlock Text="{Binding BatteryTimeRemaining}" Foreground="#8888AA"
                                   FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Visibility="{Binding IsOnBattery, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>


            </Grid>
        </Border>

        <!-- ═══ MODE TOOLBAR ═══ -->
        <Border Grid.Row="1" Background="#16213E" Padding="8,4">
            <DockPanel>
                <!-- Imaging mode buttons -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="B" Style="{StaticResource ModeButton}" Command="{Binding SetBModeCommand}" ToolTip="B-Mode"/>
                    <Button Content="M" Style="{StaticResource ModeButton}" Command="{Binding SetMModeCommand}" ToolTip="M-Mode"/>
                    <Button Content="Color" Style="{StaticResource ModeButton}" Command="{Binding SetColorDopplerCommand}" ToolTip="Color Flow Doppler"/>
                    <Button Content="Power" Style="{StaticResource ModeButton}" Command="{Binding SetPowerDopplerCommand}" ToolTip="Power Doppler"/>
                    <Button Content="PW" Style="{StaticResource ModeButton}" Command="{Binding SetSpectralDopplerCommand}" ToolTip="Spectral (PW) Doppler"/>
                    <Button Content="3D" Style="{StaticResource ModeButton}" Command="{Binding SetVolume3DCommand}" ToolTip="3D Volume"/>

                    <Rectangle Width="1" Fill="#3A3A5C" Margin="10,4"/>

                    <!-- Scan control -->
                    <Button Content="▶ Scan" Style="{StaticResource DarkButton}" Command="{Binding StartScanCommand}"
                            Width="80" Background="#006400" Foreground="White" FontWeight="Bold"/>
                    <Button Content="⏸ Freeze" Style="{StaticResource DarkButton}" Command="{Binding FreezeCommand}"
                            Width="80" Background="#B8860B" Foreground="White"/>
                    <Button Content="⏹ Stop" Style="{StaticResource DarkButton}" Command="{Binding StopScanCommand}"
                            Width="80" Background="#8B0000" Foreground="White"/>
                </StackPanel>

                <!-- Right side: presets, frame rate, mode indicator -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Presets -->
                    <TextBlock Text="Preset:" Foreground="#8888AA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PresetComboBox" Width="100" SelectedIndex="0" Style="{StaticResource DarkComboBox}" Margin="0,0,10,0"
                             ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                             SelectionChanged="PresetComboBox_SelectionChanged">
                        <ComboBoxItem Content="Abdomen" Tag="Abdomen"/>
                        <ComboBoxItem Content="OB/GYN" Tag="ObGyn"/>
                        <ComboBoxItem Content="Vascular" Tag="Vascular"/>
                        <ComboBoxItem Content="Cardiac" Tag="Cardiac"/>
                        <ComboBoxItem Content="Small Parts" Tag="SmallParts"/>
                        <ComboBoxItem Content="Renal" Tag="Renal"/>
                    </ComboBox>

                    <!-- Frame rate -->
                    <Border Background="#2D2D44" CornerRadius="3" Padding="8,2" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="FPS " Foreground="#8888AA" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FrameRate, Converter={StaticResource DoubleFmt}, ConverterParameter=F1}"
                                       Foreground="#00FF88" FontSize="14" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Current mode -->
                    <Border Background="#00B4D8" CornerRadius="3" Padding="10,2" Margin="4,0">
                        <TextBlock Text="{Binding CurrentMode, Converter={StaticResource ModeToStr}}"
                                   Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Acquisition state indicator -->
                    <Ellipse Width="12" Height="12" Margin="8,0"
                             Fill="{Binding AcquisitionState, Converter={StaticResource StateToColor}}"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>   <!-- TGC sliders -->
                <ColumnDefinition Width="*"/>    <!-- Image viewport -->
                <ColumnDefinition Width="220"/>  <!-- Right control panel -->
            </Grid.ColumnDefinitions>

            <!-- ── TGC SLIDERS ── -->
            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="TGC" Style="{StaticResource ControlLabel}" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc1}" ToolTip="Near Field"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc2}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc3}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc4}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc5}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc6}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc7}"/>
                    <Slider Style="{StaticResource TgcSlider}" Value="{Binding Tgc8}" ToolTip="Far Field"/>
                </StackPanel>
            </Border>

            <!-- ── IMAGE VIEWPORT ── -->
            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Background="Black">
                <Grid>
                    <!-- Ultrasound image display -->
                    <Image x:Name="UltrasoundImage" Source="{Binding DisplayImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"
                           MouseLeftButtonDown="UltrasoundImage_MouseLeftButtonDown"/>

                    <!-- Depth scale overlay (left edge) -->
                    <Canvas HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="40" Margin="4">
                        <TextBlock Canvas.Top="5" Canvas.Left="2" Text="0" Foreground="#00E5FF" FontSize="10" FontFamily="Consolas"/>
                        <TextBlock Canvas.Top="60" Canvas.Left="2" Foreground="#00E5FF" FontSize="10" FontFamily="Consolas"
                                   Text="{Binding Depth, Converter={StaticResource DoubleFmt}, ConverterParameter=F0}"/>
                    </Canvas>

                    <!-- Mode/depth info overlay (top-right corner) -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                        <TextBlock Text="{Binding CurrentMode, Converter={StaticResource ModeToStr}}"
                                   Foreground="#00E5FF" FontSize="16" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        <TextBlock Foreground="#00E5FF" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:F1} cm  |  {1:F1} MHz">
                                    <Binding Path="Depth"/>
                                    <Binding Path="TransmitFrequency"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Cine controls overlay (bottom) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <Button Content="⏮" Style="{StaticResource DarkButton}" Command="{Binding CineStepBackCommand}" FontSize="16" Padding="8,4"/>
                        <Button Content="⏺" Style="{StaticResource DarkButton}" Command="{Binding CineRecordCommand}" FontSize="16" Padding="8,4" Foreground="Red"/>
                        <Button Content="▶" Style="{StaticResource DarkButton}" Command="{Binding CinePlayCommand}" FontSize="16" Padding="8,4"/>
                        <Button Content="⏹" Style="{StaticResource DarkButton}" Command="{Binding CineStopCommand}" FontSize="16" Padding="8,4"/>
                        <Button Content="⏭" Style="{StaticResource DarkButton}" Command="{Binding CineStepForwardCommand}" FontSize="16" Padding="8,4"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── RIGHT CONTROL PANEL ── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Probe Connection -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="PROBE CONNECTION" Style="{StaticResource ControlLabel}" FontWeight="Bold"/>

                            <!-- Connection status indicator -->
                            <DockPanel Margin="0,4">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="{Binding CurrentConnectionState, Converter={StaticResource ProbeStateColor}}"/>
                                <TextBlock Text="{Binding ConnectionStatusText}" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Source selector -->
                            <TextBlock Text="Source" Foreground="#8888AA" FontSize="10" Margin="0,4,0,2"/>
                            <ComboBox x:Name="ProbeSourceComboBox" Style="{StaticResource DarkComboBox}"
                                     ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                     SelectedIndex="0" SelectionChanged="ProbeSourceComboBox_SelectionChanged">
                                <ComboBoxItem Content="Simulator" Tag="Simulator"/>
                                <ComboBoxItem Content="USB / Serial" Tag="UsbSerial"/>
                                <ComboBoxItem Content="Ethernet / TCP" Tag="Ethernet"/>
                            </ComboBox>

                            <!-- USB/Serial settings (visible when USB selected) -->
                            <StackPanel x:Name="UsbSettingsPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                <TextBlock Text="Serial Port" Foreground="#8888AA" FontSize="10" Margin="0,0,0,2"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="↻" Style="{StaticResource DarkButton}"
                                            Command="{Binding RefreshSerialPortsCommand}" ToolTip="Refresh ports" Width="30" Padding="4,2"/>
                                    <ComboBox x:Name="SerialPortComboBox" Style="{StaticResource DarkComboBox}"
                                             ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                             ItemsSource="{Binding AvailableSerialPorts}"
                                             SelectedItem="{Binding SerialPortName, Mode=TwoWay}"/>
                                </DockPanel>
                            </StackPanel>

                            <!-- Ethernet settings (visible when Ethernet selected) -->
                            <StackPanel x:Name="EthernetSettingsPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                <TextBlock Text="IP Address" Foreground="#8888AA" FontSize="10" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding ProbeIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#2D2D44" Foreground="White" BorderBrush="#3A3A5C"
                                         Padding="6,4" FontFamily="Consolas"/>
                            </StackPanel>

                            <!-- Connect / Disconnect / Discover buttons -->
                            <WrapPanel Margin="0,6,0,0">
                                <Button Content="🔌 Connect" Style="{StaticResource DarkButton}" Width="100"
                                        Command="{Binding ConnectProbeCommand}" Background="#006400" Foreground="White"/>
                                <Button Content="⏏ Disconnect" Style="{StaticResource DarkButton}" Width="100"
                                        Command="{Binding DisconnectProbeCommand}"/>
                                <Button Content="🔍 Discover" Style="{StaticResource DarkButton}" Width="100"
                                        Command="{Binding DiscoverProbesCommand}" ToolTip="Scan for probes"/>
                            </WrapPanel>

                            <!-- Probe info -->
                            <TextBlock Text="{Binding ProbeInfo}" Foreground="#00E5FF" FontSize="10" FontFamily="Consolas"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Gain -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="GAIN" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding Gain, Converter={StaticResource DoubleFmt}, ConverterParameter='F0 dB'}"/>
                                <Slider Minimum="0" Maximum="100" Value="{Binding Gain}" TickFrequency="5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Depth -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="DEPTH" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding Depth, Converter={StaticResource DepthDisplay}}"/>
                                <Slider Minimum="2" Maximum="30" Value="{Binding Depth}" TickFrequency="1"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Content="−" Style="{StaticResource DarkButton}" Command="{Binding DecreaseDepthCommand}" Width="40"/>
                                <Button Content="+" Style="{StaticResource DarkButton}" Command="{Binding IncreaseDepthCommand}" Width="40"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Dynamic Range -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="DYNAMIC RANGE" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding DynamicRange, Converter={StaticResource DoubleFmt}, ConverterParameter='F0 dB'}"/>
                                <Slider Minimum="30" Maximum="90" Value="{Binding DynamicRange}" TickFrequency="5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Frequency -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="FREQUENCY" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding TransmitFrequency, Converter={StaticResource DoubleFmt}, ConverterParameter='F1 MHz'}"/>
                                <Slider Minimum="1.0" Maximum="5.0" Value="{Binding TransmitFrequency}" TickFrequency="0.5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Persistence -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="PERSISTENCE" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding Persistence}"/>
                                <Slider Minimum="0" Maximum="7" Value="{Binding Persistence}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Sector Angle -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="SECTOR ANGLE" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding SectorAngle, Converter={StaticResource DoubleFmt}, ConverterParameter='F0°'}"/>
                                <Slider Minimum="30" Maximum="90" Value="{Binding SectorAngle}" TickFrequency="5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Harmonic toggle -->
                    <Border Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <TextBlock Text="HARMONIC" Style="{StaticResource ControlLabel}" VerticalAlignment="Center"/>
                            <CheckBox DockPanel.Dock="Right" IsChecked="{Binding HarmonicImaging}" HorizontalAlignment="Right"
                                      Foreground="White" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Doppler controls -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="DOPPLER" Style="{StaticResource ControlLabel}" FontWeight="Bold"/>
                            <TextBlock Text="PRF" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding DopplerPrf, Converter={StaticResource DoubleFmt}, ConverterParameter='F0 Hz'}"/>
                                <Slider Minimum="1000" Maximum="10000" Value="{Binding DopplerPrf}" TickFrequency="500"/>
                            </DockPanel>
                            <TextBlock Text="ANGLE CORRECTION" Style="{StaticResource ControlLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource ValueLabel}"
                                           Text="{Binding DopplerAngle, Converter={StaticResource DoubleFmt}, ConverterParameter='F0°'}"/>
                                <Slider Minimum="0" Maximum="80" Value="{Binding DopplerAngle}" TickFrequency="5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Measurement tools -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="MEASUREMENTS" Style="{StaticResource ControlLabel}" FontWeight="Bold"/>
                            <WrapPanel>
                                <Button Content="📏 Dist" Style="{StaticResource DarkButton}" Width="65"
                                        Command="{Binding SetMeasurementModeCommand}" CommandParameter="Distance"/>
                                <Button Content="⭕ Area" Style="{StaticResource DarkButton}" Width="65"
                                        Command="{Binding SetMeasurementModeCommand}" CommandParameter="Area"/>
                                <Button Content="📦 Vol" Style="{StaticResource DarkButton}" Width="65"
                                        Command="{Binding SetMeasurementModeCommand}" CommandParameter="Volume"/>
                                <Button Content="🔄 Vel" Style="{StaticResource DarkButton}" Width="65"
                                        Command="{Binding SetMeasurementModeCommand}" CommandParameter="Velocity"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Undo" Style="{StaticResource DarkButton}" Width="65" Command="{Binding UndoMeasurementCommand}"/>
                                <Button Content="Clear" Style="{StaticResource DarkButton}" Width="65" Command="{Binding ClearMeasurementsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Segmentation -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="SEGMENTATION (ITK-SNAP)" Style="{StaticResource ControlLabel}" FontWeight="Bold"/>
                            <ComboBox x:Name="SegmentationComboBox" Margin="0,4" SelectedIndex="0"
                                     Style="{StaticResource DarkComboBox}"
                                     ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                     SelectionChanged="SegmentationComboBox_SelectionChanged">
                                <ComboBoxItem Content="Region Growing" Tag="RegionGrowing"/>
                                <ComboBoxItem Content="Level Set (Active Contour)" Tag="LevelSet"/>
                                <ComboBoxItem Content="Watershed" Tag="Watershed"/>
                            </ComboBox>
                            <TextBlock Text="Click image to set seed point" Foreground="#666688" FontSize="10" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- DICOM -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="DICOM" Style="{StaticResource ControlLabel}" FontWeight="Bold"/>
                            <WrapPanel>
                                <Button Content="💾 Store" Style="{StaticResource DarkButton}" Command="{Binding DicomStoreCommand}"/>
                                <Button Content="📁 Save" Style="{StaticResource DarkButton}" Command="{Binding DicomSaveLocalCommand}"/>
                                <Button Content="🔍 Echo" Style="{StaticResource DarkButton}" Command="{Binding DicomEchoCommand}"/>
                                <Button Content="📋 MWL" Style="{StaticResource DarkButton}" Command="{Binding DicomQueryWorklistCommand}" ToolTip="Modality Worklist"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="#0F3460" Padding="10,4">
            <DockPanel>
                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                         Fill="{Binding AcquisitionState, Converter={StaticResource StateToColor}}"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="#8888AA" FontSize="11" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}AuraScan v1.0  |  {0}  |  {1:F1} cm  |  {2:F1} MHz  |  {3:F1} fps">
                            <Binding Path="CurrentMode" Converter="{StaticResource ModeToStr}"/>
                            <Binding Path="Depth"/>
                            <Binding Path="TransmitFrequency"/>
                            <Binding Path="FrameRate"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
